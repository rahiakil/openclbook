# Copy to .env and fill in values (never commit .env).
# Used by scripts/fabletome_api_e2e.py when python-dotenv is installed.

# --- HTTP API (same stack for Fabletome Studio + SceneWeaver browsers) ---
# From pic-new-res: cd infra/terraform-http-api && terraform output -raw api_base_url
FABLETOME_API_BASE=https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com

# --- Caller identity (jobs + manuscript routes) ---
# Pic-new-res Lambda: if Supabase is NOT configured (empty SUPABASE_URL), any stable
# string works as userId in JSON body / query — no API Gateway usage-plan key required.
FABLETOME_USER_ID=demo-sceneweaver-local

# Optional: only needed if you wrap API Gateway with an API key authorizer yourself.
# Default pic-new-res Terraform does NOT validate x-api-key in Lambda.
# FABLETOME_API_KEY=

# If Supabase IS configured on the Lambda, use a real access JWT instead of body userId:
# FABLETOME_BEARER_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Book-pipeline worker (claim / progress / complete / fail) ---
# Must match Terraform book_pipeline_worker_token (TF_VAR_book_pipeline_worker_token).
FABLETOME_WORKER_TOKEN=replace-with-openssl-rand-hex-32

# --- Optional: direct DynamoDB read in the e2e script (needs AWS creds on your machine) ---
# Table name from: terraform output -raw jobs_table_name   (often fabletome-api-jobs)
# FABLETOME_DYNAMODB_TABLE=fabletome-api-jobs
# AWS_REGION=us-east-1

# --- Optional: where remote_job_worker.py writes projects/<project_id>/ ---
# BOOK_PIPELINE_ROOT=/home/you/repos/openclaw/book-pipeline
