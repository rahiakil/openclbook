# Ollama (local — default supervisor / lab backend)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma4:26b

# Optional: Anthropic API when UI or LLM_PROVIDER selects anthropic
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_THINKING=adaptive
# ANTHROPIC_THINKING_BUDGET=10000
# LLM_PROVIDER=anthropic

# Optional: structured JSON “review / plan” steps via OpenClaw Gateway (llm-task tool)
# Leave unset to use Ollama only for every step.
# OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
# OPENCLAW_GATEWAY_TOKEN=your-gateway-token
